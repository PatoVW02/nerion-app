{
  "name": "nerion",
  "version": "1.5.1",
  "description": "Cross-platform disk space analyzer",
  "author": "patovw",
  "email": "hey@patovw.com",
  "main": "out/main/index.js",
  "scripts": {
    "postinstall": "install-electron",
    "dev": "electron-vite dev",
    "build": "electron-vite build && npm run verify:secrets",
    "preview": "electron-vite preview",
    "dist": "npm run build:scanner && npm run build && electron-builder",
    "dist:arm64": "npm run build:scanner:arm64 && npm run build && electron-builder --arm64",
    "dist:x64": "npm run build:scanner:x64 && npm run build && electron-builder --x64",
    "dist:universal": "npm run build:scanner:universal && npm run build && electron-builder --universal",
    "dist:win:x64": "npm run build:scanner:win:x64 && npm run build && electron-builder --win nsis --x64",
    "dist:all": "npm run dist:arm64 && npm run dist:x64 && npm run dist:universal",
    "release": "bash scripts/release-mac.sh",
    "release:all": "bash scripts/release-all.sh",
    "typecheck": "tsc -p tsconfig.node.json --noEmit --composite false && tsc -p tsconfig.web.json --noEmit --composite false",
    "verify:secrets": "node scripts/verify-no-bundled-secrets.mjs",
    "test": "vitest run && npm run test:scanner",
    "test:scanner": "cargo test --manifest-path native/scanner-rs/Cargo.toml && cargo build --manifest-path native/scanner-rs/Cargo.toml && node scripts/test-scanner.mjs",
    "build:scanner": "node scripts/build-scanner.mjs",
    "build:scanner:arm64": "node scripts/build-scanner.mjs --target aarch64-apple-darwin --out resources/scanner-bin",
    "build:scanner:x64": "node scripts/build-scanner.mjs --target x86_64-apple-darwin --out resources/scanner-bin",
    "build:scanner:universal": "node scripts/build-scanner.mjs --target aarch64-apple-darwin --out resources/scanner-bin-arm64 && node scripts/build-scanner.mjs --target x86_64-apple-darwin --out resources/scanner-bin-x86_64 && lipo -create resources/scanner-bin-arm64 resources/scanner-bin-x86_64 -output resources/scanner-bin && chmod +x resources/scanner-bin && rm resources/scanner-bin-arm64 resources/scanner-bin-x86_64",
    "build:scanner:win:x64": "node scripts/build-scanner.mjs --target x86_64-pc-windows-msvc --out resources/scanner-bin.exe"
  },
  "dependencies": {
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@electron-toolkit/utils": "^4.0.0",
    "electron-updater": "^6.1.0",
    "lucide-react": "^1.8.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.2",
    "electron": "^43.1.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.19",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.patricio.nerion",
    "productName": "Nerion",
    "artifactName": "Nerion-${arch}.${ext}",
    "afterPack": "scripts/after-pack.cjs",
    "afterSign": "scripts/notarize.cjs",
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.utilities",
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "binaries": [
        "Contents/Resources/scanner-bin"
      ],
      "forceCodeSigning": true,
      "notarize": false,
      "x64ArchFiles": "scanner-bin",
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true
            },
            "127.0.0.1": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      },
      "extraResources": [
        {
          "from": "resources/scanner-bin",
          "to": "scanner-bin"
        }
      ]
    },
    "win": {
      "forceCodeSigning": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "extraResources": [
        {
          "from": "resources/scanner-bin.exe",
          "to": "scanner-bin.exe"
        }
      ]
    },
    "files": [
      "out/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "PatoVW02",
      "repo": "nerion-app",
      "releaseType": "release"
    }
  },
  "allowScripts": {
    "electron-winstaller@5.4.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "fsevents@2.3.3": true
  }
}
